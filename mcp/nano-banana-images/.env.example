# Google AI Studio / Gemini API key for Nano Banana.
# Get a key from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Default Nano Banana 2 model. Other useful options:
# gemini-3.1-flash-lite-image, gemini-3.1-flash-image, gemini-3-pro-image, gemini-2.5-flash-image
NANO_BANANA_MODEL=gemini-3.1-flash-image

# WordPress site root and public URL.
DIGISAKA_WP_ROOT=C:\wamp64\www\digisaka_website
DIGISAKA_PUBLIC_BASE_URL=http://localhost/digisaka_website

# Default save location for generated website images.
DIGISAKA_IMAGE_OUTPUT_DIR=C:\wamp64\www\digisaka_website\wp-content\uploads\digisaka-generated